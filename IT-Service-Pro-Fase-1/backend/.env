# =========================================
# CONFIGURACION DE BASE DE DATOS POSTGRESQL
# =========================================
# AJUSTA estos 3 datos si tu Postgres tiene otro usuario/clave/nombre de base.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=it_service_pro
DB_USER=itservice_user
DB_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg2://itservice_user:change_me@localhost:5432/it_service_pro

# =========================================
# SEGURIDAD / JWT
# =========================================
SECRET_KEY=CBneCmMWivH5mLnU36HbK94qaihfg0vD0bIsY3GYvBaduZywEDVIcnmhXujif_ZtrB7_eESyrdMHERj9BoH-Ww
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================
# APLICACION
# =========================================
APP_NAME=IT Service Pro
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# =========================================
# CORS
# =========================================
# Cubre todos los puertos donde Vite suele arrancar si el 5173 ya estaba
# ocupado (salta automaticamente a 5174, 5175, etc.). Revisa la consola de
# "npm run dev" para confirmar cual te tomo y, si no esta en esta lista,
# agregalo (http://localhost:PUERTO y http://127.0.0.1:PUERTO).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176,http://localhost:3000,http://127.0.0.1:3000

# =========================================
# SEGURIDAD DE LOGIN
# =========================================
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# =========================================
# PAGINACION
# =========================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# =========================================
# ASISTENTE VIRTUAL (IA) - opcional, se puede dejar vacio sin romper nada
# =========================================
AI_PROVIDER=local
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
CHAT_PROVIDER_TIMEOUT_SECONDS=12
CHAT_MAX_HISTORY_MESSAGES=10
CHAT_FAST_LOCAL_ENABLED=true
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
